#main-visual-pagination {
	position: absolute;
	bottom: 69px;
	left: 50%;
	width: 400px;
	z-index: 1;
	margin-left: -200px;
	padding: 0;
}

#main-visual-pagination .swiper-pagination-bullet {
	display: inline-block;
	vertical-align: bottom;
	margin: 0 8px;
	width: 22px;
	height: 22px;
	background-color: #fff;
	opacity: 1;
	border-radius: 11px;
	transition: all 0.2s ease-in-out;
}

#main-visual-pagination .swiper-pagination-bullet-active {
	background-color: #f6b62f;
	-webkit-box-shadow: 5px 5px 8px 0px rgba(0,0,0,0.25);
	-moz-box-shadow: 5px 5px 8px 0px rgba(0,0,0,0.25);
	box-shadow: 5px 5px 8px 0px rgba(0,0,0,0.25);
}

.swiper-button-wrapper{
	z-index: 5000;
    width:400px;
    position: absolute;
    left: 50%;
    bottom: 67px;
	    margin-left: 75px;
}
.swiper-button-wrapper > button{
	
	display: inline-block;
	width: 22px; height: 26px;
	overflow: hidden;
	margin-right:5px;
	cursor: pointer;
}
.swiper-button-play{
	position: relative;
	text-indent: -5000rem;
	float: left;

	
}
.swiper-button-play:after{
	position: absolute;
	left: 0; top: 0; 
	content: "";
	width: 22px; height: 26px;
		background: url(../_common/img02/popup/icon_play02.png) no-repeat 0 0;
	   background-position: center center;
    background-repeat: no-repeat;
    background-size: 16px;
}

.swiper-button-pause{
	position: relative;
	text-indent: -5000rem;	
	float: left;
}
.swiper-button-pause:after{
	position: absolute;
	left: 0; top: 0; 
	content: "";
	width: 22px; height: 26px;
		background: url(../_common/img02/popup/icon_stop02.png) no-repeat 0 0;
	   background-position: center center;
    background-repeat: no-repeat;
    background-size: 16px;
}


.main-contents01 {
	padding: 107px 0 161px 7.40%;
	transition: all 0.2s ease-in-out;
}

.main-contents01-wrapper {
	position: relative;
	width: 100%;
	overflow: hidden;
}

.main-title01 {
	position: relative;
	display: block;
	padding-top: 48px;
	margin-bottom: 38px;
	font-size: 52px;
	line-height: 67px;
	color: #222222;
	font-weight: 300;
	letter-spacing: -1px;
}

.main-title01:before {
	position: absolute;
	top: 0;
	left: 0;
	content: "";
	display: block;
	width: 42px;
	height: 9px;
	background-color: #f6b62f;
}

.main-title01 > strong {
	margin-right: 26px;
	font-size: 58px;
	line-height: 67px;
	font-family: "Arial", Arial, sans-serif;
	font-weight: 900;
	color: #1a1a1a;
	letter-spacing: 0;
}

.main-title02 {
	position: relative;
	display: block;
	font-size: 56px;
	line-height: 71px;
	color: #ffffff;
	font-weight: 300;
	font-family: "Arial", Arial, sans-serif;
	font-weight: 900;
	letter-spacing: 0;
}

.main-title03 {
	position: relative;
	display: block;
	margin-top: 6px;
	font-size: 46px;
	line-height: 75px;
	color: #ffffff;
	font-weight: 400;
}

.main-board-slider-wrapper {
	display: block;
}

.main-board-slider-wrapper .swiper-slide {
	display: block;
	width: 530px;
}

.main-board-wrapper {
	display: block;
	width: 530px;
}

.main-board-wrapper .image {
	position: relative;
	display: block;
	width: 100%;
	padding-bottom: 60.377%;
	margin-bottom: 46px;
	overflow: hidden;
}

.main-board-wrapper .image > img {
	transition: all 0.2s ease-in-out;
	-webkit-transform: scale3d(1, 1, 1);
	transform: scale3d(1, 1, 1);
}

.main-board-wrapper:hover .image > img,
.main-board-wrapper:focus .image > img {
	-webkit-transform: scale3d(1.02, 1.02, 1.02);
	transform: scale3d(1.02, 1.02, 1.02);
}

.main-board-area {
	display: block;
}

.main-board-area .date {
	display: block;
	margin-bottom: 6px;
	color: #212121;
	font-size: 20px;
	line-height: 27px;
}

.main-board-area .title {
	display: block;
	margin-bottom: 10px;
	font-size: 28px;
	line-height: 36px;
	font-weight: 700;
	color: #333333;

	word-break: keep-all;
	display:-webkit-box;
	-webkit-line-clamp: 2;
	-webkit-box-orient: vertical;
	max-height: 72px;
	overflow: hidden;
	text-overflow: ellipsis;
	overflow: hidden;
}

.main-board-area .substance {
	display: block;
	color: #818181;
	font-size: 18px;
	line-height: 28px;
	word-break: keep-all;
	display:-webkit-box;
	-webkit-line-clamp: 4;
	-webkit-box-orient: vertical;
	max-height: 112px;
	overflow: hidden;
	text-overflow: ellipsis;
	overflow: hidden;
}

.main-board-option-wrapper {
	margin-top: 130px;
	width: calc(100% - 7.40%);
	transition: all 0.2s ease-in-out;
}

.main-board-option-wrapper:after {
	display: block;
	content: "";
	clear: both;
}

.main-board-option-wrapper button {
	float: left;
	display: block;
	width: 24px;
	height: 20px;
	background-size: 24px 20px;
	background-repeat: no-repeat;
	background-position: 0 0;
	text-indent: -5000rem;

}

.main-board-option-wrapper .main-board-prev01 {
	background-image: url(../img02/main/btn_previous01.png);
}

.main-board-option-wrapper .main-board-next01 {
	background-image: url(../img02/main/btn_next01.png);
}

.main-board-option-wrapper #main-board-pagination01 {
	position: static;
	float: left;
	width: auto;
	margin: 0 23px;
	font-size: 20px;
	line-height: 20px;
	font-weight: 700;
	color: #919191
}

.main-board-option-wrapper #main-board-pagination01 > .swiper-pagination-current {
	color: #2f1a1a;
}

.main-board-option-wrapper .swiper-thumbnails {
	margin-top: 6px;
}

.main-board-option-wrapper .swiper-thumbnails:after {
	content: "";
	clear: both;
	display: block;
}

.main-board-option-wrapper .swiper-thumbnails > button {
	float: left;
	display: block;
	margin-left: 15px;
	width: 10px;
	height: 10px;
	background-color: #dedede
}

.main-board-option-wrapper .swiper-thumbnails > button.active {
	background-color: #212121
}

.main-board-option-wrapper .swiper-thumbnails > button:first-child {
	margin-left: 0;
}

.main-contents02 {
	position: relative;
	min-height: 760px;
}

.main-ch-vision-wrapper {
	position: relative;
	padding: 0 7.4%;
	z-index: 10;
	transition: all 0.2s ease-in-out;
}

.main-ch-vision-wrapper .title-wrapper {
	position: relative;
	top: -41px;
	z-index: 10000;
	height: 442px;
}

.main-ch-vision-wrapper .title-wrapper > h2 {
	display: table;
	width: 150px;
	height: 140px;
	margin-bottom: 29px;
	text-align: center;
	background-image: url(../img02/main/bg_title_vision01.gif);
	background-repeat: no-repeat;
	background-color: #f5ae26;
	background-position: right center;
}

.main-ch-vision-wrapper .title-wrapper > h2 > strong {
	display: table-cell;
	vertical-align: middle;
	color: #fff;
	font-size: 26px;
	line-height: 27px;
	font-weight: 500;
}

.main-ch-vision-wrapper .title-wrapper > p {
	display: block;
	width: 681px;
	padding-bottom: 14px;
	font-size: 24px;
	line-height: 38px;
	color: #fff;
	background-image: url(../img02/main/bg_word_vision01.png);
	background-repeat: no-repeat;
	background-position: right bottom;
	background-size: 119px 50px;
}

.movie-wrapper {
	position: absolute;
	top: 0;
	left: 0;
	display: block;
	width: 100%;
	height: 760px;
	background-color: #000;
	overflow: hidden;
	z-index: 0;
}

.movie-wrapper:after {
	position: absolute;
	top: 0;
	left: 0;
	content: "";
	display: block;
	width: 100%;
	height: 100%;
	background: rgba(0,0,0, 0.3);
	z-index: 10
}

.movie-wrapper > iframe,
.movie-wrapper > .youtube {
	position: absolute;
	top: -52px;
	left: 50%;
	margin-left: -960px;
	display: block;
	width: 1920px;
	height: 1080px;
}

.main-board-wrapper02 {
	position: relative;
	padding: 0 7.4%;
	z-index: 5;
	transition: all 0.2s ease-in-out;
}

.main-board-wrapper02:after {
	content: "";
	clear: both;
	display: block;
}

.main-board-area02 {
	display: block;
	margin-bottom: 100px;
}

.main-board-area02:after {
	content: "";
	clear: both;
	display: block;
}

.main-board-box02 {
	position: relative;
	float: left;
	width: 58.99%;
	-webkit-box-shadow: 9px 9px 32px 0px rgba(0,0,0,0.05);
	-moz-box-shadow: 9px 9px 32px 0px rgba(0,0,0,0.05);
	box-shadow: 9px 9px 32px 0px rgba(0,0,0,0.05);
}

.main-board-box02 > ul {
	position: relative;
	padding-left: 19.3614%;
	height: 462px;
	background-color: #fff;

}

.main-board-box02 > ul > li {
	display: block;
}

.main-board-box02 > ul > li > button {
	position: absolute;
	left: 0;
	width: 19.3614%;
	height: 57.75px;
	background-color: #f6f6f6;
	border-bottom: 1px solid #dddddd;
	color: #000000;
	font-size: 22px;
}

.main-board-box02 > ul > li > button > span {
	position: relative;
	display: block;
	z-index: 5;
}

.main-board-box02 > ul > li > button:before {
	position: absolute;
	bottom: 0;
	left: 0;
	content: "";
	display: block;
	width: 100%;
	height: 0;
	background-color: rgba(221, 221, 221, 0);
	transition: all 0.2s ease-in-out;
}

.main-board-box02 > ul > li > button:hover:before,
.main-board-box02 > ul > li > button:focus:before {
	height: 100%;
	background-color: rgba(221, 221, 221, 1);
}

.main-board-box02 > ul > li:nth-of-type(1) > button {
	top: 0;
}

.main-board-box02 > ul > li:nth-of-type(2) > button {
	top: 57.75px;
}

.main-board-box02 > ul > li:nth-of-type(3) > button {
	top: calc(57.75px  * 2);
}

.main-board-box02 > ul > li:nth-of-type(4) > button {
	top: calc(57.75px  * 3);
}

.main-board-box02 > ul > li:nth-of-type(5) > button {
	top: calc(57.75px  * 4);
}

.main-board-box02 > ul > li:nth-of-type(6) > button {
	top: calc(57.75px  * 5);
}
.main-board-box02 > ul > li:nth-of-type(7) > button {
	top: calc(57.75px  * 6);
}

.main-board-box02 > ul > li:nth-of-type(8) > button {
	top: calc(57.75px  * 7);
	border-bottom: 1px solid #f6f6f6;
}


.main-board-box02 > ul > li > button.active {
	background-color: #00af62 !important;
	color: #fff;
	border-bottom: 1px solid #00af62 !important;
	font-weight: 500;
}

.main-board-box02 > ul > li > button.active:before {
	display: none;
}


.main-board-box02 > ul > li > button.active + .main-board-group02 {
	display: block;
}

.main-board-group02 {
	display: none;
	padding: 57px 52px 0 52px;
}

.main-board-group02 > ul {
	display: block;
}

.main-board-group02 > ul > li {
	display: block;
	margin-bottom: 9px;
}

.main-board-group02 > ul > li > a {
	position: Relative;
	display: block;
	padding-left: 23px;
}

.main-board-group02 > ul > li > a:before {
	position: absolute;
	top: 9px;
	left: 0;
	content: "";
	width: 6px;
	height: 6px;
	border: 3px solid #e3e3e3;
	border-radius: 50%;
	transition: all 0.2s ease-in-out;
}

.main-board-group02 > ul > li > a:hover:before,
.main-board-group02 > ul > li > a:focus:before {
	border-color: #00af62 !important
}


.main-board-group02 > ul > li > a > .title {
	display: block;
	color: #333333;
	font-size: 22px;
