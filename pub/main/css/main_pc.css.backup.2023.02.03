}

.main-schdule-area > ul > li > a {
	position: relative;
	display: block;
	height: 100%;
	padding-left: 25.08%;
}

.main-schdule-area > ul > li > a:before {
	position: absolute;
	top: 0;
	left: 25.08%;
	content: "";
	display: block;
	width: 0;
	height: 100%;
	background-color: rgba(0, 0, 0, 0.025);
	z-index: 1;
	transition: all 0.2s ease-in-out;
}

.main-schdule-area > ul > li > a:hover:before,
.main-schdule-area > ul > li > a:focus:before {
	left: 0;
	width: 100%;
}

.main-schdule-area > ul > li > a .yymmnn {
	position: absolute;
	top: 0;
	left: 0;
	display: block;
	width: 25.08%;
