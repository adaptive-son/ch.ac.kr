	color: #cccccc;
	font-size: 17px;
	line-height: 23px;
}


.main-board-group02 > ul > li > a:hover > .title,
.main-board-group02 > ul > li > a:focus > .title,
.main-board-group02 > ul > li > a:hover .date,
.main-board-group02 > ul > li > a:focus .date {
	font-weight: 500;
	color: #333333;
	transition: all 0.2s ease-in-out;
}


.main-board-group02 .no-data {
	position: relative;
	display: block;
	width: 100%;
	height: 348px;
	text-align: center;
}

.main-board-group02 .no-data > p {
	position: absolute;
	top: 50%;
	left: 0;
	display: block;
	width: 100%;
	vertical-align: middle;
	font-size: 20px;
	line-height: 24px;
	margin-top: -12px;
	color: #212121;
	font-weight: 500;
