	background-color: #f6f6f6;
	border-bottom: 1px solid #dfdfdf;
	text-align: center;
}

.main-schdule-area > ul > li > a .yymmnn > dl {
	position: absolute;
	top: 50%;
	left: 0;
	display: block;
	width: 100%;
	color: #075077;
	margin-top: -23.5px;
