}

.main-schdule-area {
	position: relative;
	display: block;
	width: 100%;
	height: 462px;
	background-color: #fff;
	-webkit-box-shadow: 9px 9px 32px 0px rgba(0,0,0,0.05);
	-moz-box-shadow: 9px 9px 32px 0px rgba(0,0,0,0.05);
	box-shadow: 9px 9px 32px 0px rgba(0,0,0,0.05);
}

.main-schdule-area > ul {
	display: block;
}

.main-schdule-area > ul > li {
	display: block;
	height: 115.5px;
	border-bottom: 1px solid #e9e9e9
}

.main-schdule-area > ul > li:last-child {
