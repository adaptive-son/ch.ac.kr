	background: linear-gradient(90deg, rgba(245,246,253,1) 0%, rgba(246,244,247,1) 30%, rgba(249,242,237,1) 100%);
}

.main-press-wrapper:after {
	position: absolute;
	top: 345px;
	right: 0;
	content: "";
	display: block;
	width: calc(100% - 77px);
	height: 277px;
