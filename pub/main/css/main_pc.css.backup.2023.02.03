}

.main-schdule-area > ul > li > a .yymmnn > dl > dt {
	display: block;
	font-size: 15px;
	line-height: 18px;
}

.main-schdule-area > ul > li > a .yymmnn > dl > dd {
	font-size: 30px;
	line-height: 29px;
	font-weight: 700;
}

.main-schdule-area > ul > li:nth-of-type(1) > a .yymmnn {
	background-color: #005aab;
	border-bottom: 1px solid #005aab;
}

.main-schdule-area > ul > li:nth-of-type(4) > a .yymmnn {
	border-bottom: 0;
}

.main-schdule-area > ul > li:nth-of-type(1) > a .yymmnn > dl {
	color: #fff;
}

.main-schdule-area > ul > li > a .information {
