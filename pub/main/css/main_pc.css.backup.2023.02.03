}

.main-board-area02 .btn-more {
	position: absolute;
	top: -77px;
	right: 0;
	display: table;
	width: 58px;
	height: 58px;
	border-radius: 50%;
	background-color: rgba(255, 255, 255, 0.15);
	text-indent: -5000rem;
	text-align: center;
