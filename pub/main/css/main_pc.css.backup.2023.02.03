.main .btn-mobile-back {
	display: none !important
}

/* main visual */
.main-visual-wrapper {
	position: relative;
	overflow: hidden;
}

.main-visual-area {
	background-color: #000;
}

.main-visual-box {
	position: relative;
	display: block;
	height: 949px;
	overflow: hidden;
	background-color: #000;
}

.main-visual-box .bg {
	display: none;
    transform: matrix(1.15, 0, 0, 1.15, 0, 0);
    -webkit-transition: all 0.4s ease;
    -moz-transition: all 0.4s ease;
    -ms-transition: all 0.4s ease;
    -o-transition: all 0.4s ease;
    transition: all 0.4s ease;
}


#main-visual-slider .swiper-slide-active .main-visual-box .bg  {
    transition-delay: 0.4s !important;
    transform: matrix(1.0, 0, 0, 1.0, 0, 0);
    -webkit-transition: all 6.0s ease;
    -moz-transition: all 6.0s ease;
    -ms-transition: all 6.0s ease;
    -o-transition: all 6.0s ease;
    transition: all 6.0s ease;
}

.main-visual-box .bg.pc {
	position: absolute;
	top: 0;
	left: 50%;
	display: block;
	width: 1920px;
	margin-left: -960px;

}

.visual1 .slogan01 {
	position: absolute;
	top: 50%;
	left: 50%;
	width: 725px;
	margin-left: -362.5px;
	background-image: url(../img02/main/bg_award01.png);
	background-repeat: no-repeat;
	background-size: 725px 252px;
	background-position: center top;
	transform: translate(0, -50%);
}

.visual1 .slogan0101 {
	background-image: none;
}

.visual1 .slogan01 > ul {
	display: block;
	max-width: 367px;
	padding-top: 80px;
	margin: 0 auto;

}

.visual1 .slogan01 > ul > li {
	float: left;
	width: 49%;
	margin-left: 0.5%;
	text-align: center;
	transition: all 0.2s ease-in-out;
	opacity:0;
}

.visual1 .slogan01 > ul > li:nth-of-type(1) {
	margin-left: 0;
	transition-delay: 0.25s;
}

.visual1 .slogan01 > ul > li:nth-of-type(2) {
	transition-delay: 0.5s;
}

.visual1 .slogan01 > ul > li:nth-of-type(3) {
	transition-delay: .75s;
}

.swiper-slide-active.visual1 .slogan01 > ul > li {
	opacity: 1;
	
	width:100%; /* 230203 1개 */
}


.visual1 .slogan01 > ul > li > img {
	display: block;
	margin: 0 auto;
}

.visual1 .slogan01 .word01 {
	position: relative;
	display: block;
	top: -12px;
}

.visual1 .slogan0101 .word01 {
	top: 73px;
}

.visual1 .slogan01 .word01 > img {
	display: block;
	margin: 0 auto;
	transform: translate3d(0, 30px, 0);
	-ms-transform: translate3d(0, 30px, 0);
	transition: all .5s ease-in-out;;
	opacity:0;
}

.swiper-slide-active.visual1 .slogan01 .word01 > img {
	transform: none;
	opacity: 1;
}


.visual2 .slogan02 .word02 {
	position: absolute;
	top: 427px;
	left: 0;
	display: block;
	width: 100%;
}

.visual2 .slogan02 .word02 > img {
	display: block;
	margin: 0 auto;
	transform: translate3d(0, 20px, 0);
	-ms-transform: translate3d(0, 20px, 0);
	transition: all .4s ease-in-out;;
	opacity:0;
}

.visual2 .slogan02 .word02 > img:nth-of-type(1) {
	transition-delay: 0.25s;
}

.visual2 .slogan02 .word02 > img:nth-of-type(2) {
	transition-delay: 0.75s;
}

.swiper-slide-active.visual2 .slogan02 .word02 > img {
	transform: none;
	opacity: 1;
}

.visual3 .slogan03 {
	position: absolute;
	bottom: 0;
	left: 0;
	width: 670px;
	height: 225px;
	padding-top: 58px;
	padding-left: 142px;
	text-align: left;
}

.visual3 .slogan03 .bg01 {
	position: absolute;
	top: 0;
	left: 0;
	display: block;
	width: 0;
	height: 100%;
	background-color: rgba(5, 169, 216, 0);
	transition: all 0.5s ease-in-out;
}

.visual3 .slogan03 .word03 {
	position: relative;
	color: #ecffff;
	font-size: 50px;
	line-height: 56px;
	font-weight: 500;
	letter-spacing: -1px;
}

.visual3 .slogan03:before {
	position: absolute;
	top: 45px;
	left: 89px;
	content: "";
	display: block;
	width: 42px;
	height: 44px;
	background-image: url(../img02/main/main_visual0301.png);
	background-repeat: no-repeat;
	background-size: 42px 44px;
	background-position: 0 0;
	z-index: 5;
	transform: translate3d(0, -20px, 0);
	-ms-transform: translate3d(0, -20px, 0);
	transition: all .4s ease-in-out;;
	opacity: 0;
	transition-delay: 0.75s;
}

.visual3 .slogan03:after {
	position: absolute;
	top: -70px;
	right: 57px;
	content: "";
	display: block;
	width: 107px;
	height: 100px;
	background-image: url(../img02/main/main_visual0302.png);
	background-repeat: no-repeat;
	background-size: 107px 100px;
	background-position: 0 0;
	transform: translate3d(0, -20px, 0);
	-ms-transform: translate3d(0, -20px, 0);
	transition: all .4s ease-in-out;;
	z-index: 5;
	opacity: 0;
	transition-delay: 1s;
}


.visual3 .slogan03 .word03 > span {
	display: block;
	text-shadow: 0 3px 9px rgba(0, 0, 0, 0.24);
	transform: translate3d(0, 20px, 0);
	-ms-transform: translate3d(0, 20px, 0);
	transition: all .4s ease-in-out;;
	opacity:0;
}

.visual3 .slogan03 .word03 > span:nth-of-type(1) {
	transition-delay: 0.5s;
}

.visual3 .slogan03 .word03 > span:nth-of-type(2) {
	transition-delay: 0.75s;
}

.swiper-slide-active.visual3  .slogan03 .bg01 {
	width: 100%;
	background-color: rgba(5, 169, 216, 1);
}

.swiper-slide-active.visual3 .slogan03 .word03 > span,
.swiper-slide-active.visual3 .slogan03:before,
.swiper-slide-active.visual3 .slogan03:after {
	transform: none;
	opacity: 1;
}

