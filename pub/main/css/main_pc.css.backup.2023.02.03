}

.main-press-area {
	display: block;
	padding-top: 27px;
}

.main-press-slider-wrapper {
	display: block;
	width: 100%;
}

.main-press-slider-wrapper {
	display: block;
}

.main-press-slider-wrapper .swiper-slide {
	display: block;
	width: 466px;
}

.main-press-box {
	display: block;
	width: 466px;
