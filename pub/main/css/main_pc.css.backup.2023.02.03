.main-quickmenu-wrapper > .quickmenu-wrapper > ul > li > button:hover:before,
.main-quickmenu-wrapper > .quickmenu-wrapper > ul > li > button:focus:before,
.main-quickmenu-wrapper > .quickmenu-wrapper > ul > li > button.active:before {
