}

.main-press-box .image {
	position: relative;
	display: block;
	width: 100%;
	padding-bottom: 318px;
	margin-bottom: 46px;
	overflow: hidden;
}

.main-press-box .image > img {
	transition: all 0.2s ease-in-out;
	-webkit-transform: scale3d(1, 1, 1);
	transform: scale3d(1, 1, 1);
}

.main-press-box:hover .image > img,
.main-press-box:focus .image > img {
	-webkit-transform: scale3d(1.02, 1.02, 1.02);
	transform: scale3d(1.02, 1.02, 1.02);
}

.main-press {
	display: block;
	text-align: center
}

.main-press .title {
	display: block;
	margin-bottom: 10px;
	font-size: 26px;
	line-height: 34px;
	font-weight: 700;
	color: #424242;

	word-break: keep-all;
	display:-webkit-box;
	-webkit-line-clamp: 2;
	-webkit-box-orient: vertical;
	max-height: 68px;
	overflow: hidden;
	text-overflow: ellipsis;
	overflow: hidden;
}

.main-press .substance {
	display: block;
	color: #888888;
	font-size: 17px;
	line-height: 26px;
	word-break: keep-all;
	display:-webkit-box;
	-webkit-line-clamp: 4;
	-webkit-box-orient: vertical;
	max-height: 104px;
	overflow: hidden;
	text-overflow: ellipsis;
	overflow: hidden;
}

